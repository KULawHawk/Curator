# Build artifacts
build/
dist/
*.egg-info/
*.egg
__pycache__/
*.py[cod]
*$py.class
*.so

# Virtual environments
.venv/
venv/
env/
ENV/

# IDE / editor
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# Testing
.pytest_cache/
.hypothesis/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
coverage.xml
*.cover

# Type checkers
.mypy_cache/
.ruff_cache/
.pyre/

# Mutation testing (v1.7.150) — mutmut writes a SQLite cache at repo root.
# Not committed; future mutation testing arc may want to pin location.
.mutmut-cache

# Curator-specific
# We don't commit the user-data DB or logs
*.db
*.db-journal
*.db-wal
*.db-shm
*.log

# The Github/ folder contains the procurement repos.
# We commit the README.md, PROCUREMENT_INDEX.md, and CURATOR_RESEARCH_NOTES.md
# but NOT the procured source ZIPs and extracted folders (they're external).
Github/[0-9]*/
Github/*.zip

# But keep the docs!
!Github/PROCUREMENT_INDEX.md
!Github/CURATOR_RESEARCH_NOTES.md

# OS-level junk
desktop.ini
$RECYCLE.BIN/
