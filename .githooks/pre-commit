#!/bin/sh
# Curator pre-commit hook (v1.7.73)
#
# Runs three pytest lints before allowing a commit:
#   1. Lesson #50 lint (v1.7.32): no literal Unicode glyphs in
#      src/curator/cli/ outside util.py (prevents cp1252 crashes).
#   2. Lesson #66+#67 lint (v1.7.72): every ORDER BY in
#      src/curator/storage/repositories/ has a deterministic tie-breaker
#      (prevents the OS x Python matrix flakiness class v1.7.66 swept).
#   3. DRY ANSI lint (v1.7.73): no inline ANSI-strip regex in tests/
#      outside conftest.py (prevents regression of v1.7.68's strip_ansi
#      fixture hoist).
#
# Why: even with the pytest-level lints, a developer can skip pytest
# before commit and push code that crashes cp1252 capture, introduces
# non-deterministic SQLite ordering, or re-introduces inline regex
# duplication. This hook closes those gaps by making the lints
# mandatory at commit time.
#
# Activation (one-time, per clone):
#     git config core.hooksPath .githooks
#
# Bypass (when intentional, e.g. emergency hotfix without working pytest):
#     git commit --no-verify
#
# Cost: runs in ~600ms because it executes a single pytest function, not
# the full suite. Slowest part is Python startup + Qt import; the actual
# scan finishes in microseconds.
#
# Compatibility:
#   - POSIX shell (works under Git for Windows' bundled sh.exe, mac, linux)
#   - Requires a working venv at .venv/Scripts/python.exe (Windows) or
#     .venv/bin/python (Unix). Falls back to system `python` if missing.

set -e

# Locate Python interpreter. Try Windows venv first, then Unix venv, then
# system python. Bail out with a helpful message if none works.
if [ -x ".venv/Scripts/python.exe" ]; then
    PYTHON=".venv/Scripts/python.exe"
elif [ -x ".venv/bin/python" ]; then
    PYTHON=".venv/bin/python"
elif command -v python >/dev/null 2>&1; then
    PYTHON="python"
elif command -v python3 >/dev/null 2>&1; then
    PYTHON="python3"
else
    echo "pre-commit: no Python interpreter found." >&2
    echo "pre-commit: activate .venv or install python on PATH." >&2
    echo "pre-commit: to bypass this hook, run: git commit --no-verify" >&2
    exit 1
fi

# Run all three lint tests. Quiet mode so the commit summary stays
# readable when the hooks pass; pytest emits the helpful diagnostic
# message automatically when a lint fails, so we don't need to add
# anything.
QT_QPA_PLATFORM=offscreen "$PYTHON" -m pytest \
    tests/unit/test_cli_util.py::test_no_literal_glyphs_in_cli_outside_util \
    tests/unit/test_repo_order_by_lint.py::test_every_order_by_has_deterministic_tie_breaker \
    tests/unit/test_repo_ansi_lint.py::test_no_inline_ansi_strip_regex_outside_conftest \
    -q --no-header 2>&1 | tail -5

# If pytest exited non-zero, refuse the commit.
PYTEST_EXIT=${PIPESTATUS:-$?}
if [ "$PYTEST_EXIT" != "0" ]; then
    echo "" >&2
    echo "pre-commit: a lint check failed. Commit refused." >&2
    echo "pre-commit: fix the issue flagged above, or run with --no-verify to bypass." >&2
    exit "$PYTEST_EXIT"
fi

exit 0
